{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "atoms-demo",
  "main": "worker.mjs",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "ratelimits": [
    {
      "name": "AGENT_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 6,
        "period": 60
      }
    }
  ]
}
